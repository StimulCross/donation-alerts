{
	"$schema": "https://turborepo.org/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"cache": true,
			"outputs": ["lib/**"]
		},
		"rebuild": {
			"dependsOn": ["^rebuild"],
			"cache": true,
			"outputs": ["lib/**"]
		},
		"clean": {},
		"lint": {
			"cache": true
		},
		"test": {
			"dependsOn": ["^test"],
			"cache": true
		},
		"check-types": {}
	}
}
