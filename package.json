{
	"version": "4.0.0",
	"name": "donation-alerts",
	"repository": "git+https://github.com/StimulCross/donation-alerts.git",
	"author": "Stimul Cross <stimulcross@gmail.com>",
	"license": "MIT",
	"description": "",
	"private": true,
	"packageManager": "pnpm@10.32.1",
	"type": "module",
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"build": "turbo run build",
		"rebuild": "turbo run rebuild",
		"clean": "turbo run clean",
		"lint": "turbo run lint",
		"lint:fix": "eslint . --fix",
		"format:check": "prettier --config \"prettier.config.cjs\" --check packages",
		"format:fix": "prettier --config \"prettier.config.cjs\" --write packages",
		"check-types": "turbo run check-types",
		"prepare": "husky",
		"preversion": "pnpm run rebuild && pnpm run format:check && pnpm run lint && pnpm run test",
		"postversion": "pnpm i",
		"prepublishOnly": "pnpm run rebuild && pnpm run format:check && pnpm run lint && pnpm run test",
		"docs": "typedoc && node fix-docs.mjs",
		"clean:docs": "rimraf ./docs",
		"test": "vitest run",
		"test:verbose": "vitest --reporter verbose --logHeapUsage",
		"test:cov": "vitest run --coverage",
		"test:cov:verbose": "vitest --coverage --reporter verbose --logHeapUsage",
		"eslint-configs": "pnpm --filter=@donation-alerts/eslint-configs",
		"typescript-config": "pnpm --filter=@donation-alerts/typescript-config",
		"common": "pnpm --filter=@donation-alerts/common",
		"api-call": "pnpm --filter=@donation-alerts/api-call",
		"auth": "pnpm --filter=@donation-alerts/auth",
		"api": "pnpm --filter=@donation-alerts/api",
		"events": "pnpm --filter=@donation-alerts/events"
	},
	"devDependencies": {
		"@commitlint/cli": "^19.7.1",
		"@stimulcross/commitlint-config": "^2.0.0",
		"@stimulcross/eslint-config-base": "^2.0.0",
		"@stimulcross/eslint-config-node": "^2.0.0",
		"@stimulcross/eslint-config-typescript": "^2.0.0",
		"@stimulcross/prettier-config": "^2.0.0",
		"@types/node": "^25.0.3",
		"@vitest/coverage-v8": "^4.0.16",
		"del-cli": "^7.0.0",
		"eslint": "^9.39.2",
		"globals": "^17.0.0",
		"husky": "^9.1.7",
		"lerna": "^8.2.0",
		"lint-staged": "^15.4.3",
		"node-html-parser": "^7.0.1",
		"prettier": "^3.5.2",
		"tsx": "^4.21.0",
		"turbo": "^2.4.4",
		"typedoc": "~0.27.9",
		"typescript": "^5.9.3",
		"vitest": "^4.0.16"
	}
}
