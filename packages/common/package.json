{
	"name": "@donation-alerts/common",
	"version": "4.0.0",
	"description": "Common utils and types that are used in other @donation-alerts packages.",
	"keywords": [
		"donation-alerts",
		"api",
		"donations",
		"tips"
	],
	"author": "StimulCross <stimulcross@gmail.com>",
	"license": "MIT",
	"homepage": "https://github.com/StimulCross/donation-alerts/tree/main/packages/common#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/StimulCross/donation-alerts.git",
		"directory": "packages/common"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		}
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"rebuild": "pnpm run clean && pnpm run build",
		"clean": "del-cli lib *.tsbuildinfo",
		"test": "tsx --test \"tests/**/*.spec.ts\""
	},
	"files": [
		"LICENSE",
		"README.md",
		"lib",
		"!lib/**/*.d.ts.map",
		"!lib/**/*.js.map"
	],
	"dependencies": {
		"klona": "^2.0.6",
		"qs": "^6.14.1"
	},
	"devDependencies": {
		"@types/qs": "^6.14.0"
	}
}
