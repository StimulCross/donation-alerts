{
	"name": "@donation-alerts/api",
	"version": "4.0.0",
	"description": "Interact with Donation Alerts API.",
	"keywords": [
		"donation-alerts",
		"api",
		"donations",
		"tips"
	],
	"author": "StimulCross <stimulcross@gmail.com>",
	"license": "MIT",
	"homepage": "https://github.com/StimulCross/donation-alerts/tree/main/packages/api#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/StimulCross/donation-alerts.git",
		"directory": "packages/api"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20"
	},
	"type": "module",
	"sideEffects": false,
	"main": "./lib/index.js",
	"types": "./lib/index.d.ts",
	"exports": {
		".": {
			"types": "./lib/index.d.ts",
			"default": "./lib/index.js"
		}
	},
	"packageManager": "pnpm@10.32.1",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"rebuild": "pnpm run clean && pnpm run build",
		"clean": "del-cli lib *.tsbuildinfo",
		"lint": "eslint src tests",
		"lint:fix": "eslint src tests --fix",
		"format:check": "prettier --check src",
		"format:fix": "prettier --write src",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"test": "tsx --test \"tests/**/*.spec.ts\""
	},
	"files": [
		"LICENSE",
		"README.md",
		"lib",
		"!lib/**/*.d.ts.map",
		"!lib/**/*.js.map"
	],
	"dependencies": {
		"@d-fischer/rate-limiter": "^1.0.1",
		"@donation-alerts/api-call": "4.0.0",
		"@donation-alerts/common": "4.0.0",
		"@stimulcross/logger": "^7.0.0",
		"cross-sha256": "^1.2.0"
	},
	"peerDependencies": {
		"@donation-alerts/auth": "4.0.0"
	},
	"devDependencies": {
		"@donation-alerts/auth": "4.0.0",
		"@donation-alerts/eslint-configs": "workspace:*",
		"@donation-alerts/typescript-config": "workspace:*"
	}
}
