{
	"compilerOptions": {
		"composite": true,
		"module": "node16",
		"moduleResolution": "nodenext",
		"target": "ES2023",
		"lib": ["ES2023", "DOM"],
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"forceConsistentCasingInFileNames": true,
		"noImplicitReturns": true,
		"strict": true,
		"noUnusedLocals": true,
		"experimentalDecorators": true,
		"isolatedModules": true,
		"esModuleInterop": true
	}
}
